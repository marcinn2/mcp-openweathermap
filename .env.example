# OpenWeatherMap API Configuration
# The server's upstream credential, used to call OpenWeatherMap. Required for
# both transports. Never sent by clients.
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Transport Configuration (optional)
MCP_TRANSPORT=stdio  # or httpStream
# PORT=3000
# MCP_ENDPOINT=/mcp
# HOST=0.0.0.0   # bind address for httpStream (default: all interfaces)

# HTTP Stream Authentication (access token, separate from the API key above)
# When set, every HTTP request must present a matching Bearer access token:
#   Authorization: Bearer <your_mcp_access_token>
# Use a comma-separated list to issue distinct tokens to different clients.
# Leave unset to disable token auth (open endpoint).
# MCP_AUTH_TOKEN=changeme-generate-a-strong-random-token

# CORS (HTTP stream transport only)
# Comma-separated list of allowed origins. Defaults to "*" (all origins) if unset.
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
